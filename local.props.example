<Project>
  <PropertyGroup>
    <!-- COPY THIS FILE TO local.props AND EDIT YOUR PATHS -->
    
    <!-- Path to your Slay the Spire 2 installation -->
    <!-- Common locations:
         C:\Program Files (x86)\Steam\steamapps\common\Slay the Spire 2
    -->
    <STS2GamePath>YOUR_STEAM_PATH\steamapps\common\Slay the Spire 2</STS2GamePath>
    
    <!-- Path to Godot 4.5.1 Mono executable -->
    <!-- Download from: https://godotengine.org/download/archive/4.5.1-stable/ -->
    <GodotExePath>YOUR_GODOT_PATH\Godot_v4.5.1-stable_mono_win64.exe</GodotExePath>

    <!-- Optional: override where PathPlanner.dll, PathPlanner.json, PathPlanner.pck are copied for sharing. -->
    <!-- Default if omitted: $(ProjectDir)dist\PathPlanner-friend (same as next to this repo) -->
    <!-- <FriendModsOutputDir>C:\path\to\PathPlanner-share</FriendModsOutputDir> -->
    <!-- Linux friend bundle: PathPlanner.pck (Linux export) + dll + json under FriendModsOutputDir\linux (default). -->
    <!-- <FriendLinuxModsOutputDir>C:\path\to\PathPlanner-share\linux</FriendLinuxModsOutputDir> -->
    <!-- Skip second Godot export if Linux templates are not installed: <BuildFriendLinuxPack>false</BuildFriendLinuxPack> -->
  </PropertyGroup>
</Project>